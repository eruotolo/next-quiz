// Schema — Aulika
// Sistema de Evaluación en Línea para Instituciones Educativas
// All IDs use PostgreSQL native UUID. See docs in src/lib/rut.ts for RUT normalization.

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ─── Enums de dominio ────────────────────────────────────────────────────────

enum Plan {
    FREE
    DOCENTE
    COLEGIO
    INSTITUCIONAL
}

enum SubscriptionStatus {
    pending
    authorized
    active
    paused
    cancelled
    failed
}

enum PaymentStatus {
    APPROVED
    PENDING
    REJECTED
    REFUNDED
}

// ─── Catálogos ───────────────────────────────────────────────────────────────

model UserRole {
    id        String   @id @default(uuid()) @db.Uuid
    name      String   @unique
    users     User[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model AcademicInstitution {
    id                   String         @id @default(uuid()) @db.Uuid
    name                 String         @unique
    slug                 String         @unique
    phone                String
    address              String
    city                 String
    campus               String?
    country              String
    email                String?
    active               Boolean        @default(true)
    plan                 Plan           @default(FREE)
    activatedAt          DateTime?
    planExpiresAt        DateTime?
    mpSubscriptionId     String?
    mpCustomerId         String?
    allowedEmailDomains  String[]       @default([])
    // Plan interno (no comercial) asignado por el SuperAdmin. Si está seteado,
    // sus límites tienen prioridad sobre los del plan comercial.
    customPlanId         String?        @db.Uuid
    customPlan           CustomPlan?    @relation(fields: [customPlanId], references: [id], onDelete: SetNull)
    // SEO
    seoTitle             String?
    seoDescription       String?
    seoKeywords          String[]       @default([])
    users                User[]
    exams                Exam[]
    groups               Group[]
    subscriptions        Subscription[]
    auditLogs            AuditLog[]
    createdAt            DateTime       @default(now())
    updatedAt            DateTime       @updatedAt

    @@index([customPlanId])
}

// ─── Users & Groups ──────────────────────────────────────────────────────────

model Group {
    id                    String               @id @default(uuid()) @db.Uuid
    name                  String
    stream                String?
    tutorId               String?              @db.Uuid
    tutor                 User?                @relation("GroupTutor", fields: [tutorId], references: [id], onDelete: SetNull)
    academicInstitutionId String?              @db.Uuid
    academicInstitution   AcademicInstitution? @relation(fields: [academicInstitutionId], references: [id], onDelete: SetNull)
    users                 User[]
    professors            User[]               @relation("ProfessorGroups")
    exams                 Exam[]
    createdAt             DateTime             @default(now())
    updatedAt             DateTime             @updatedAt

    @@index([tutorId])
    @@index([academicInstitutionId])
}

model User {
    id                    String               @id @default(uuid()) @db.Uuid
    name                  String
    lastname              String
    email                 String               @unique
    rut                   String               @unique
    phone                 String?              @unique
    password              String?
    userRoleId            String?              @db.Uuid
    userRole              UserRole?            @relation(fields: [userRoleId], references: [id], onDelete: SetNull)
    academicInstitutionId String?              @db.Uuid
    academicInstitution   AcademicInstitution? @relation(fields: [academicInstitutionId], references: [id], onDelete: SetNull)
    groupId               String?              @db.Uuid
    group                 Group?               @relation(fields: [groupId], references: [id], onDelete: SetNull)
    professorGroups       Group[]              @relation("ProfessorGroups")
    tutorOfGroups         Group[]              @relation("GroupTutor")
    active                Boolean              @default(true)
    results               Result[]
    answers               Answer[]
    createdExams          Exam[]               @relation("ExamCreatedBy")
    auditLogs             AuditLog[]
    createdAt             DateTime             @default(now())
    updatedAt             DateTime             @updatedAt

    @@index([userRoleId])
    @@index([academicInstitutionId])
    @@index([groupId])
}

enum QuestionType {
    UNICA
    MULTIPLE
}

enum QuestionDifficulty {
    FACIL
    MEDIA
    DIFICIL
}

// ─── Exams ───────────────────────────────────────────────────────────────────

model Exam {
    id                    String               @id @default(uuid()) @db.Uuid
    title                 String
    timeLimit             Int
    active                Boolean              @default(false)
    maxGrade              Float                @default(7)
    passingGrade          Float                @default(4)
    passingPercentage     Int                  @default(60)
    antiCheatEnabled      Boolean              @default(false)
    subject               String?
    unit                  String?
    scheduledAt           DateTime?
    closesAt              DateTime?
    randomizeOptions      Boolean              @default(false)
    randomizeQuestions    Boolean              @default(false)
    lockTabSwitch         Boolean              @default(false)
    oneAttempt            Boolean              @default(true)
    uniqueIp              Boolean              @default(false)
    academicInstitutionId String?              @db.Uuid
    academicInstitution   AcademicInstitution? @relation(fields: [academicInstitutionId], references: [id], onDelete: SetNull)
    createdById           String?              @db.Uuid
    createdBy             User?                @relation("ExamCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
    groups                Group[]
    questions             Question[]
    results               Result[]
    answers               Answer[]
    createdAt             DateTime             @default(now())
    updatedAt             DateTime             @updatedAt

    @@index([active])
    @@index([academicInstitutionId])
    @@index([createdById])
}

model Question {
    id           String             @id @default(uuid()) @db.Uuid
    text         String
    points       Int                @default(1)
    order        Int                @default(0)
    questionType QuestionType       @default(UNICA)
    subject      String?
    unit         String?
    difficulty   QuestionDifficulty @default(MEDIA)
    tags         String[]           @default([])
    usageCount   Int                @default(0)
    feedback     String?
    examId       String             @db.Uuid
    exam         Exam               @relation(fields: [examId], references: [id], onDelete: Cascade)
    options      Option[]
    answers      Answer[]
    createdAt    DateTime           @default(now())
    updatedAt    DateTime           @updatedAt

    @@index([examId])
    @@index([subject, unit])
    @@index([difficulty])
}

model Option {
    id         String   @id @default(uuid()) @db.Uuid
    text       String
    isCorrect  Boolean  @default(false)
    questionId String   @db.Uuid
    question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
    answers    Answer[]
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    @@index([questionId])
}

// ─── Results & Answers ───────────────────────────────────────────────────────

model Answer {
    id               String    @id @default(uuid()) @db.Uuid
    attemptKey       String
    studentId        String    @db.Uuid
    student          User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
    examId           String    @db.Uuid
    exam             Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
    questionId       String    @db.Uuid
    question         Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
    optionId         String    @db.Uuid
    option           Option    @relation(fields: [optionId], references: [id], onDelete: Cascade)
    ip               String?
    markedForReview  Boolean   @default(false)
    timeSpentMs      Int?
    answeredAt       DateTime?
    createdAt        DateTime  @default(now())
    updatedAt        DateTime  @updatedAt

    @@unique([attemptKey, questionId, optionId])
    @@index([attemptKey])
    @@index([studentId])
    @@index([examId])
}

model TabSwitchEvent {
    id         String   @id @default(uuid()) @db.Uuid
    attemptKey String
    studentId  String   @db.Uuid
    examId     String   @db.Uuid
    durationMs Int
    createdAt  DateTime @default(now())

    @@index([attemptKey])
    @@index([examId])
}

model Result {
    id          String   @id @default(uuid()) @db.Uuid
    studentId   String   @db.Uuid
    student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
    examId      String   @db.Uuid
    exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
    score       Int
    maxScore    Int
    answers     Json
    completedAt DateTime @default(now())

    @@unique([studentId, examId])
    @@index([studentId])
    @@index([examId])
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
    id                    String   @id @default(uuid()) @db.Uuid
    action                String
    entity                String?
    entityId              String?  @db.Uuid
    actorId               String?  @db.Uuid
    actorEmail            String?
    actorRole             String?
    academicInstitutionId String?  @db.Uuid
    status                String
    ip                    String?
    userAgent             String?
    metadata              Json?
    createdAt             DateTime @default(now())

    actor       User?                @relation(fields: [actorId], references: [id], onDelete: SetNull)
    institution AcademicInstitution? @relation(fields: [academicInstitutionId], references: [id], onDelete: SetNull)

    @@index([createdAt])
    @@index([action])
    @@index([actorId])
    @@index([academicInstitutionId])
    @@index([entity, entityId])
}

// ─── App Config ───────────────────────────────────────────────────────────────

model AppConfig {
    id        String   @id @default(uuid()) @db.Uuid
    key       String   @unique
    value     String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// ─── Plans & Subscriptions ────────────────────────────────────────────────────

model PlanLimits {
    id              String   @id @default(uuid()) @db.Uuid
    plan            Plan     @unique
    maxGroups       Int?
    maxAdmins       Int?
    maxProfessors   Int?
    maxStudents     Int?
    maxExamsPerYear Int?
    description     String?
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt
}

// Planes internos creados por el SuperAdmin (no comerciales, no visibles para
// el cliente final). Se asignan a una institución para darle límites a medida.
model CustomPlan {
    id              String                @id @default(uuid()) @db.Uuid
    name            String                @unique
    maxGroups       Int?
    maxAdmins       Int?
    maxProfessors   Int?
    maxStudents     Int?
    maxExamsPerYear Int?
    description     String?
    institutions    AcademicInstitution[]
    createdAt       DateTime              @default(now())
    updatedAt       DateTime              @updatedAt
}

model Subscription {
    id                    String               @id @default(uuid()) @db.Uuid
    academicInstitutionId String?              @db.Uuid
    academicInstitution   AcademicInstitution? @relation(fields: [academicInstitutionId], references: [id], onDelete: SetNull)
    plan                  Plan
    billing               String               @default("monthly")
    status                SubscriptionStatus   @default(pending)
    mpSubscriptionId      String?
    mpPlanId              String?
    amount                Float?
    currency              String?              @default("CLP")
    startedAt             DateTime?
    expiresAt             DateTime?
    cancelledAt           DateTime?
    pausedAt              DateTime?
    metadata              Json?
    payments              Payment[]
    createdAt             DateTime             @default(now())
    updatedAt             DateTime             @updatedAt

    @@index([academicInstitutionId])
    @@index([mpSubscriptionId])
    @@index([status])
}

model Payment {
    id             String         @id @default(uuid()) @db.Uuid
    subscriptionId String         @db.Uuid
    subscription   Subscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
    mpPaymentId    String?        @unique
    amount         Float
    currency       String         @default("CLP")
    status         PaymentStatus
    paidAt         DateTime?
    periodStart    DateTime?
    periodEnd      DateTime?
    rawPayload     Json?
    createdAt      DateTime       @default(now())

    @@index([subscriptionId])
    @@index([status])
    @@index([paidAt])
}

model WebhookEvent {
    id         String   @id @default(uuid()) @db.Uuid
    provider   String   @default("mercadopago")
    topic      String
    externalId String
    rawPayload Json
    processed  Boolean  @default(false)
    error      String?
    receivedAt DateTime @default(now())

    @@index([topic, externalId])
    @@index([receivedAt])
}
