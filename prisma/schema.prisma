// Schema — Aulika
// Sistema de Evaluación en Línea para Instituciones Educativas
// All IDs use PostgreSQL native UUID. See docs in src/lib/rut.ts for RUT normalization.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums de dominio ────────────────────────────────────────────────────────

enum Plan {
  FREE
  DOCENTE
  COLEGIO
  INSTITUCIONAL
}

enum SubscriptionStatus {
  pending
  authorized
  active
  paused
  cancelled
  failed
}

enum PaymentStatus {
  APPROVED
  PENDING
  REJECTED
  REFUNDED
}

// Tipo de institución. Define el label dinámico de la jerarquía académica
// (Carrera / Nivel / Área / Especialidad) en la UI. Las instituciones previas
// quedan en OTRO; las nuevas eligen su tipo al crearse.
enum InstitutionType {
  COLEGIO
  LICEO_TECNICO
  PREUNIVERSITARIO
  UNIVERSIDAD
  INSTITUTO_PROFESIONAL
  CFT
  OTRO
}

// Tipo de período académico. El detalle legible vive en `AcademicPeriod.name`
// (libre y único por institución), por lo que el enum solo agrupa de forma laxa.
enum PeriodType {
  ANUAL
  SEMESTRE
  TRIMESTRE
  MODULO
  OTRO
}

// ─── Catálogos ───────────────────────────────────────────────────────────────

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AcademicInstitution {
  id                  String           @id @default(uuid()) @db.Uuid
  name                String           @unique
  slug                String           @unique
  phone               String
  address             String
  city                String
  campus              String?
  country             String
  email               String?
  active              Boolean          @default(true)
  // Tipo de institución (jerarquía académica). Default OTRO para datos previos.
  type                InstitutionType  @default(OTRO)
  // Institución sandbox del modo demo público. Su contenido es efímero y se
  // limpia por sesión (al cerrar sesión) y por cron diario de respaldo.
  isDemo              Boolean          @default(false)
  plan                Plan             @default(FREE)
  activatedAt         DateTime?
  planExpiresAt       DateTime?
  // Flags de habilitación y plan por producto. Permiten comercializar Exámenes
  // (Aulika) y Aula Virtual (LMS) de forma independiente. `examsEnabled` parte
  // en true (producto core); `lmsEnabled` parte en false y se activa al comprar
  // un pack LMS. Los `*PlanCode` referencian la fila de PlanLimits por producto.
  examsEnabled        Boolean          @default(true)
  examsPlanCode       String?          @default("exams_free")
  examsPlanExpiresAt  DateTime?
  lmsEnabled          Boolean          @default(false)
  lmsPlanCode         String?          @default("lms_free")
  lmsPlanExpiresAt    DateTime?
  mpSubscriptionId    String?
  mpCustomerId        String?
  allowedEmailDomains String[]         @default([])
  // Plan interno (no comercial) asignado por el SuperAdmin. Si está seteado,
  // sus límites tienen prioridad sobre los del plan comercial.
  customPlanId        String?          @db.Uuid
  customPlan          CustomPlan?      @relation(fields: [customPlanId], references: [id], onDelete: SetNull)
  // SEO
  seoTitle            String?
  seoDescription      String?
  seoKeywords         String[]         @default([])
  users               User[]
  exams               Exam[]
  groups              Group[]
  programs            Program[]
  academicPeriods     AcademicPeriod[]
  subscriptions       Subscription[]
  auditLogs           AuditLog[]
  bankQuestions       BankQuestion[]
  lmsCourses          LmsCourse[]
  lmsCategories       LmsCategory[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([customPlanId])
}

// ─── Jerarquía académica ─────────────────────────────────────────────────────

// Programa = Carrera / Nivel / Área / Especialidad según el tipo de institución.
model Program {
  id                    String               @id @default(uuid()) @db.Uuid
  name                  String
  code                  String?
  description           String?
  academicInstitutionId String               @db.Uuid
  academicInstitution   AcademicInstitution  @relation(fields: [academicInstitutionId], references: [id], onDelete: Cascade)
  groups                Group[]
  courseSections        CourseSection[]
  coordinators          ProgramCoordinator[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@unique([academicInstitutionId, name])
  @@index([academicInstitutionId])
}

// Período académico (2025 - Anual / Semestre 1 / Módulo 2…). El `name` es la
// clave legible única por institución; `year` y `type` son metadata agrupadora.
model AcademicPeriod {
  id                    String              @id @default(uuid()) @db.Uuid
  name                  String
  year                  Int
  type                  PeriodType
  startDate             DateTime?
  endDate               DateTime?
  isActive              Boolean             @default(false)
  academicInstitutionId String              @db.Uuid
  academicInstitution   AcademicInstitution @relation(fields: [academicInstitutionId], references: [id], onDelete: Cascade)
  courseSections        CourseSection[]
  groups                Group[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([academicInstitutionId, name])
  @@index([academicInstitutionId])
}

// Materia dictada (asignatura/ramo). Pieza central de la jerarquía: cruza
// programa (opcional → transversal), período, profesores (N:M co-docencia) y
// grupo (opcional → se autocrea en universidades).
model CourseSection {
  id         String         @id @default(uuid()) @db.Uuid
  name       String
  code       String?
  programId  String?        @db.Uuid
  program    Program?       @relation(fields: [programId], references: [id], onDelete: SetNull)
  periodId   String         @db.Uuid
  period     AcademicPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  professors User[]         @relation("CourseSectionTeachers")
  groupId    String?        @db.Uuid
  group      Group?         @relation(fields: [groupId], references: [id], onDelete: SetNull)
  exams      Exam[]
  lmsCourses LmsCourse[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([programId, periodId, name, groupId])
  @@index([programId])
  @@index([periodId])
  @@index([groupId])
}

// Jefe de Carrera = vínculo Profesor↔Programa (no es un 5° rol). Otorga alcance
// extendido dentro de su programa, resuelto en Server Actions vía scoping.
model ProgramCoordinator {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId String   @db.Uuid
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, programId])
  @@index([programId])
}

// ─── Users & Groups ──────────────────────────────────────────────────────────

model Group {
  id                    String               @id @default(uuid()) @db.Uuid
  name                  String
  stream                String?
  tutorId               String?              @db.Uuid
  tutor                 User?                @relation("GroupTutor", fields: [tutorId], references: [id], onDelete: SetNull)
  academicInstitutionId String?              @db.Uuid
  academicInstitution   AcademicInstitution? @relation(fields: [academicInstitutionId], references: [id], onDelete: SetNull)
  // FK opcional al programa académico (jerarquía). Nullable → no breaking.
  programId             String?              @db.Uuid
  program               Program?             @relation(fields: [programId], references: [id], onDelete: SetNull)
  // FK opcional al período (semestre) del grupo. Nullable → no breaking.
  periodId              String?              @db.Uuid
  period                AcademicPeriod?      @relation(fields: [periodId], references: [id], onDelete: SetNull)
  users                 User[]
  professors            User[]               @relation("ProfessorGroups")
  exams                 Exam[]
  courseSections        CourseSection[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([tutorId])
  @@index([academicInstitutionId])
  @@index([programId])
  @@index([periodId])
}

model User {
  id                    String                  @id @default(uuid()) @db.Uuid
  name                  String
  lastname              String
  email                 String                  @unique
  rut                   String                  @unique
  phone                 String?
  password              String?
  // B2C: token de activación de cuenta (flujo de primer ingreso). El estudiante
  // compra un curso, se crea este usuario inactivo, y se le envía por email un
  // enlace `/examen/activar?token=...` para que defina su contraseña. La fecha
  // de expiración (`activationTokenExp`) vence a las 24h de emitido el token.
  activationToken       String?                 @unique
  activationTokenExp    DateTime?
  userRoleId            String?                 @db.Uuid
  userRole              UserRole?               @relation(fields: [userRoleId], references: [id], onDelete: SetNull)
  academicInstitutionId String?                 @db.Uuid
  academicInstitution   AcademicInstitution?    @relation(fields: [academicInstitutionId], references: [id], onDelete: SetNull)
  groupId               String?                 @db.Uuid
  group                 Group?                  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  professorGroups       Group[]                 @relation("ProfessorGroups")
  tutorOfGroups         Group[]                 @relation("GroupTutor")
  taughtSections        CourseSection[]         @relation("CourseSectionTeachers")
  coordinatedPrograms   ProgramCoordinator[]
  active                Boolean                 @default(true)
  results               Result[]
  answers               Answer[]
  examAttempts          ExamAttempt[]
  createdExams          Exam[]                  @relation("ExamCreatedBy")
  auditLogs             AuditLog[]
  createdBankQuestions  BankQuestion[]          @relation("BankQuestionCreatedBy")
  createdLmsCourses     LmsCourse[]             @relation("LmsCourseCreatedBy")
  lmsEnrollments        LmsEnrollment[]
  lmsLessonProgress     LmsLessonProgress[]
  lmsSubmissions        LmsSubmission[]
  lmsGrades             LmsGrade[]
  forumThreads          LmsForumThread[]
  forumPosts            LmsForumPost[]
  lmsNotifications      LmsNotification[]
  lmsStreak             LmsStreak?
  lmsUserBadges         LmsUserBadge[]
  lmsPointEvents        LmsPointEvent[]
  leaderboardOptOuts    LmsLeaderboardOptOut[]
  lmsCertificates       LmsCertificate[]
  liveSessionsCreated   LmsLiveSession[]        @relation("LmsLiveSessionCreatedBy")
  liveAttendances       LmsLiveAttendance[]
  liveChatMessages      LmsLiveChatMessage[]
  whiteboardSnapshots   LmsWhiteboardSnapshot[]
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([userRoleId])
  @@index([academicInstitutionId])
  @@index([groupId])
}

enum QuestionType {
  UNICA
  MULTIPLE
}

enum QuestionDifficulty {
  FACIL
  MEDIA
  DIFICIL
}

// ─── Enums del LMS (Aula Virtual) ────────────────────────────────────────────

enum LessonType {
  VIDEO
  DOCUMENTO
  TEXTO
  ENLACE
  EXAMEN
  TAREA
  EN_VIVO
}

enum EnrollmentStatus {
  ACTIVO
  COMPLETADO
  RETIRADO
}

// Estado de una orden de compra B2C (pago único de un curso público).
enum OrderStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

// ─── Fase 2 (Fase actual): Tareas y Libro de Calificaciones ──────────────────

enum LmsSubmissionStatus {
  PENDIENTE
  ENTREGADO
  CALIFICADO
  ATRASADO
}

enum LmsGradebookItemType {
  EXAMEN
  TAREA
  PARTICIPACION
  MANUAL
}

// ─── Fase 4: Gamificación (Puntos, Rachas, Insignias) ────────────────────────

enum LmsPointSource {
  LESSON_COMPLETED
  ASSIGNMENT_SUBMITTED
  ASSIGNMENT_GRADED
  EXAM_PASSED
  FORUM_POST
  MANUAL
  STREAK_BONUS
}

// ─── Exams ───────────────────────────────────────────────────────────────────

model Exam {
  id                    String               @id @default(uuid()) @db.Uuid
  title                 String
  timeLimit             Int
  active                Boolean              @default(false)
  maxGrade              Float                @default(7)
  passingGrade          Float                @default(4)
  passingPercentage     Int                  @default(60)
  antiCheatEnabled      Boolean              @default(false)
  subject               String?
  unit                  String?
  scheduledAt           DateTime?
  closesAt              DateTime?
  randomizeQuestions    Boolean              @default(false)
  lockTabSwitch         Boolean              @default(false)
  oneAttempt            Boolean              @default(true)
  uniqueIp              Boolean              @default(false)
  academicInstitutionId String?              @db.Uuid
  academicInstitution   AcademicInstitution? @relation(fields: [academicInstitutionId], references: [id], onDelete: SetNull)
  createdById           String?              @db.Uuid
  createdBy             User?                @relation("ExamCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  // Aísla los exámenes creados por cada visitante del modo demo (un id por
  // login). Null para exámenes reales. Permite cupo FREE y limpieza por sesión.
  demoSessionId         String?
  // Metadata de categorización académica (jerarquía). NO decide quién rinde:
  // la fuente de verdad del gating sigue siendo la relación M2M `groups`.
  courseSectionId       String?              @db.Uuid
  courseSection         CourseSection?       @relation(fields: [courseSectionId], references: [id], onDelete: SetNull)
  groups                Group[]
  questions             Question[]
  results               Result[]
  answers               Answer[]
  attempts              ExamAttempt[]
  lmsLessons            LmsLesson[]
  lmsGradebookItems     LmsGradebookItem[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([active])
  @@index([academicInstitutionId])
  @@index([createdById])
  @@index([demoSessionId])
  @@index([courseSectionId])
}

model Question {
  id           String             @id @default(uuid()) @db.Uuid
  text         String
  points       Int                @default(1)
  order        Int                @default(0)
  questionType QuestionType       @default(UNICA)
  subject      String?
  unit         String?
  difficulty   QuestionDifficulty @default(MEDIA)
  tags         String[]           @default([])
  usageCount   Int                @default(0)
  feedback     String?
  examId       String             @db.Uuid
  exam         Exam               @relation(fields: [examId], references: [id], onDelete: Cascade)
  options      Option[]
  answers      Answer[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([examId])
  @@index([subject, unit])
  @@index([difficulty])
}

model Option {
  id         String   @id @default(uuid()) @db.Uuid
  text       String
  isCorrect  Boolean  @default(false)
  questionId String   @db.Uuid
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers    Answer[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([questionId])
}

// ─── Results & Answers ───────────────────────────────────────────────────────

model Answer {
  id              String    @id @default(uuid()) @db.Uuid
  attemptKey      String
  studentId       String    @db.Uuid
  student         User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examId          String    @db.Uuid
  exam            Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionId      String    @db.Uuid
  question        Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  optionId        String    @db.Uuid
  option          Option    @relation(fields: [optionId], references: [id], onDelete: Cascade)
  ip              String?
  markedForReview Boolean   @default(false)
  timeSpentMs     Int?
  answeredAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([attemptKey, questionId, optionId])
  @@index([attemptKey])
  @@index([studentId])
  @@index([examId])
}

// Intento en curso de un examen. Permite reanudar tras un re-login sin
// resetear el tiempo ni perder respuestas (la corrección lee por attemptKey).
// endsAt nulo = el estudiante todavía no presionó "Comenzar examen".
model ExamAttempt {
  id         String    @id @default(uuid()) @db.Uuid
  attemptKey String    @unique
  studentId  String    @db.Uuid
  student    User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examId     String    @db.Uuid
  exam       Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  startedAt  DateTime?
  endsAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([studentId, examId])
  @@index([examId])
}

model TabSwitchEvent {
  id         String   @id @default(uuid()) @db.Uuid
  attemptKey String
  studentId  String   @db.Uuid
  examId     String   @db.Uuid
  durationMs Int
  createdAt  DateTime @default(now())

  @@index([attemptKey])
  @@index([examId])
}

model Result {
  id          String   @id @default(uuid()) @db.Uuid
  studentId   String   @db.Uuid
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examId      String   @db.Uuid
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  score       Int
  maxScore    Int
  answers     Json
  completedAt DateTime @default(now())

  @@unique([studentId, examId])
  @@index([studentId])
  @@index([examId])
}

// ─── Question Bank ──────────────────────────────────────────────────────────
// Banco de preguntas reutilizable por institución. Independiente del ciclo de
// vida de un examen: al agregar una pregunta del banco a un examen, se clona a
// Question + Option (copyBankQuestionToExam). Así el banco persiste aunque el
// examen se borre, y los docentes acumulan una biblioteca por asignatura/unidad.
model BankQuestion {
  id                    String               @id @default(uuid()) @db.Uuid
  text                  String
  questionType          QuestionType         @default(UNICA)
  subject               String?
  unit                  String?
  difficulty            QuestionDifficulty   @default(MEDIA)
  tags                  String[]             @default([])
  feedback              String?
  academicInstitutionId String?              @db.Uuid
  academicInstitution   AcademicInstitution? @relation(fields: [academicInstitutionId], references: [id], onDelete: SetNull)
  createdById           String?              @db.Uuid
  createdBy             User?                @relation("BankQuestionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  options               BankOption[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([academicInstitutionId])
  @@index([subject, unit])
  @@index([difficulty])
  @@index([createdById])
}

model BankOption {
  id             String       @id @default(uuid()) @db.Uuid
  text           String
  isCorrect      Boolean      @default(false)
  bankQuestionId String       @db.Uuid
  bankQuestion   BankQuestion @relation(fields: [bankQuestionId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([bankQuestionId])
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id                    String   @id @default(uuid()) @db.Uuid
  action                String
  entity                String?
  entityId              String?  @db.Uuid
  actorId               String?  @db.Uuid
  actorEmail            String?
  actorRole             String?
  academicInstitutionId String?  @db.Uuid
  status                String
  ip                    String?
  userAgent             String?
  metadata              Json?
  createdAt             DateTime @default(now())

  actor       User?                @relation(fields: [actorId], references: [id], onDelete: SetNull)
  institution AcademicInstitution? @relation(fields: [academicInstitutionId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action])
  @@index([actorId])
  @@index([academicInstitutionId])
  @@index([entity, entityId])
}

// ─── App Config ───────────────────────────────────────────────────────────────

model AppConfig {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Plans & Subscriptions ────────────────────────────────────────────────────

// Límites por plan comercial. Estrategia híbrida retrocompatible: la columna
// `plan` (enum) se mantiene sin `@unique`, y se agrega `planCode` para identificar
// packs flexibles por producto. Los planes heredados conviven con `planCode`
// nulo; los nuevos packs por producto (exámenes / LMS) se identifican por el
// `planCode`. La unicidad real la garantiza `@@unique([plan, planCode])`.
model PlanLimits {
  id              String   @id @default(uuid()) @db.Uuid
  plan            Plan
  planCode        String?
  maxGroups       Int?
  maxAdmins       Int?
  maxProfessors   Int?
  maxStudents     Int?
  maxExamsPerYear Int?
  maxPrograms     Int?
  maxCourses      Int?
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([plan, planCode])
  @@index([planCode])
}

// Planes internos creados por el SuperAdmin (no comerciales, no visibles para
// el cliente final). Se asignan a una institución para darle límites a medida.
model CustomPlan {
  id              String                @id @default(uuid()) @db.Uuid
  name            String                @unique
  maxGroups       Int?
  maxAdmins       Int?
  maxProfessors   Int?
  maxStudents     Int?
  maxExamsPerYear Int?
  maxPrograms     Int?
  maxCourses      Int?
  description     String?
  institutions    AcademicInstitution[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model Subscription {
  id                    String               @id @default(uuid()) @db.Uuid
  academicInstitutionId String?              @db.Uuid
  academicInstitution   AcademicInstitution? @relation(fields: [academicInstitutionId], references: [id], onDelete: SetNull)
  plan                  Plan
  billing               String               @default("monthly")
  status                SubscriptionStatus   @default(pending)
  mpSubscriptionId      String?
  mpPlanId              String?
  amount                Float?
  currency              String?              @default("CLP")
  startedAt             DateTime?
  expiresAt             DateTime?
  cancelledAt           DateTime?
  pausedAt              DateTime?
  metadata              Json?
  payments              Payment[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([academicInstitutionId])
  @@index([mpSubscriptionId])
  @@index([status])
}

model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  subscriptionId String        @db.Uuid
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  mpPaymentId    String?       @unique
  amount         Float
  currency       String        @default("CLP")
  status         PaymentStatus
  paidAt         DateTime?
  periodStart    DateTime?
  periodEnd      DateTime?
  rawPayload     Json?
  createdAt      DateTime      @default(now())

  @@index([subscriptionId])
  @@index([status])
  @@index([paidAt])
}

model WebhookEvent {
  id         String   @id @default(uuid()) @db.Uuid
  provider   String   @default("mercadopago")
  topic      String
  externalId String
  rawPayload Json
  processed  Boolean  @default(false)
  error      String?
  receivedAt DateTime @default(now())

  @@index([topic, externalId])
  @@index([receivedAt])
}

// ─── LMS (Aula Virtual) ──────────────────────────────────────────────────────
// Cubre Fase 1: cursos, módulos, lecciones, inscripciones y progreso. Los
// modelos usan el prefijo `Lms` para no colisionar con `CourseSection` (materias
// del motor de exámenes) ni con `Course` (palabra reservada conceptual del LMS).
// El plan maestro del Aula Aulika define Course, Module, Lesson, LessonProgress
// y Enrollment como núcleo; aquí se materializan con FK a Exam para que una
// lección pueda embeber un examen Aulika (LessonType.EXAMEN).

// Curso del Aula Virtual. Unidad de negocio de mayor jerarquía: agrupa módulos
// y lecciones. Independiente del motor de exámenes pero vinculable a una materia
// existente (CourseSection) para mantener coherencia con la jerarquía académica.
model LmsCourse {
  id                    String                 @id @default(uuid()) @db.Uuid
  title                 String
  description           String?
  coverImageUrl         String?
  published             Boolean                @default(false)
  // Fase 5: Emite certificado automáticamente cuando el estudiante completa el curso.
  certificateEnabled    Boolean                @default(false)
  // Fase 5: Habilita resúmenes automáticos con IA para lecciones TEXTO.
  aiSummaryEnabled      Boolean                @default(false)
  // B2C: visibilidad en el catálogo público y precio de venta (CLP).
  // Null/0 = gratis. `isPublic` habilita el curso para checkout externo.
  isPublic              Boolean                @default(false)
  price                 Float?
  academicInstitutionId String?                @db.Uuid
  academicInstitution   AcademicInstitution?   @relation(fields: [academicInstitutionId], references: [id], onDelete: Cascade)
  // Vínculo opcional a la materia del motor de exámenes. Si se setea, los
  // grupos que ya están asignados a esa materia quedan auto-inscriptos al LMS.
  courseSectionId       String?                @db.Uuid
  courseSection         CourseSection?         @relation(fields: [courseSectionId], references: [id], onDelete: SetNull)
  createdById           String?                @db.Uuid
  createdBy             User?                  @relation("LmsCourseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  modules               LmsModule[]
  enrollments           LmsEnrollment[]
  gradebookItems        LmsGradebookItem[]
  forums                LmsForum[]
  pointEvents           LmsPointEvent[]
  leaderboardOptOuts    LmsLeaderboardOptOut[]
  certificates          LmsCertificate[]
  liveSessions          LmsLiveSession[]
  lmsOrders             LmsOrder[]
  categories            LmsCourseCategory[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([academicInstitutionId])
  @@index([courseSectionId])
  @@index([published])
  @@index([createdById])
}

// Módulo del curso. Agrupa lecciones bajo un título y orden pedagógico.
model LmsModule {
  id          String      @id @default(uuid()) @db.Uuid
  title       String
  description String?
  order       Int         @default(0)
  courseId    String      @db.Uuid
  course      LmsCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     LmsLesson[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([courseId])
}

// Lección. Unidad pedagógica mínima. Soporta múltiples tipos: video (Mux),
// documento (Vercel Blob / PDF), texto enriquecido (Tiptap JSON), enlace,
// examen Aulika embebido (FK a Exam) o tarea (binding con Assignment en Fase 2).
model LmsLesson {
  id            String              @id @default(uuid()) @db.Uuid
  title         String
  type          LessonType          @default(TEXTO)
  order         Int                 @default(0)
  // Contenido de la lección
  contentJson   Json? // Texto enriquecido (Tiptap)
  videoAssetId  String? // ID de Mux (playback id)
  videoUploadId String? // ID de upload de Mux (polling)
  fileUrl       String? // URL del documento (Vercel Blob)
  externalLink  String? // Enlace externo
  durationSec   Int? // Duración estimada (videos/lecturas)
  // Fase 5: Resumen generado por IA para lecciones TEXTO. Cacheado; se regenera on demand.
  summaryJson   Json? // { summary: string, keyPoints: string[], generatedAt: string }
  // Integración con Aulika: la lección embebe un examen por FK. Setear type=EXAMEN
  // implica examId obligatorio (validado en Server Actions).
  examId        String?             @db.Uuid
  exam          Exam?               @relation(fields: [examId], references: [id], onDelete: SetNull)
  moduleId      String              @db.Uuid
  module        LmsModule           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress      LmsLessonProgress[]
  assignment    LmsAssignment?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([moduleId])
  @@index([examId])
}

// Inscripción de un estudiante a un curso del LMS. Una sola inscripción activa
// por usuario/curso (constraint @@unique). El progreso global se calcula a
// partir de LmsLessonProgress.
model LmsEnrollment {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @db.Uuid
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String           @db.Uuid
  course      LmsCourse        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status      EnrollmentStatus @default(ACTIVO)
  progressPct Int              @default(0)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([userId])
}

// Progreso individual por lección. Una fila por (user, lesson). `lastSeenSec`
// guarda el segundo de reproducción para videos (sección Fase 1, base para
// reanudar en Fase 4+).
model LmsLessonProgress {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String    @db.Uuid
  lesson      LmsLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  lastSeenSec Int?
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([userId, lessonId])
  @@index([lessonId])
}

// ─── B2C: Órdenes de compra de cursos públicos ───────────────────────────────
// Registro y trazabilidad de la compra de un curso LMS por un estudiante
// externo (pago único vía MercadoPago). La orden nace PENDIENTE al generar la
// preferencia de pago y pasa a APROBADO al recibir el webhook de MercadoPago
// (`/api/webhooks/mercadopago-b2c`), que dispara la matriculación atómica.
//
// Desde Fase 8 la orden puede ser de un curso individual (`kind=COURSE`) o de
// un pack por categoría (`kind=CATEGORY_BUNDLE`, `categoryId` seteado). El
// webhook valida que exactamente uno de los dos esté presente.
model LmsOrder {
  id              String      @id @default(uuid()) @db.Uuid
  studentRut      String
  studentName     String
  studentLastname String
  studentEmail    String
  kind            B2cOrderKind @default(COURSE)
  courseId        String?     @db.Uuid
  course          LmsCourse?  @relation(fields: [courseId], references: [id], onDelete: Restrict)
  categoryId      String?     @db.Uuid
  category        LmsCategory? @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  amount          Float
  status          OrderStatus @default(PENDIENTE)
  mpPreferenceId  String?
  mpPaymentId     String?     @unique
  enrolledUserId  String?     @db.Uuid
  enrollmentId    String?     @db.Uuid
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([courseId])
  @@index([categoryId])
  @@index([studentRut])
  @@index([status])
  @@index([createdAt])
}

// Tipo de orden B2C. COURSE = curso individual; CATEGORY_BUNDLE = pack completo
// de una categoría (inscribe al alumno en todos los cursos asociados).
enum B2cOrderKind {
  COURSE
  CATEGORY_BUNDLE
}

// ─── Fase 2: Tareas (Assignment/Submission) ──────────────────────────────────
// Una tarea está atada 1:1 a una lección de tipo TAREA (LmsLesson). Las entregas
// de los estudiantes se registran en LmsSubmission con el archivo (Vercel Blob)
// o texto entregado, fecha y estado del flujo (PENDIENTE → ENTREGADO → CALIFICADO).
model LmsAssignment {
  id           String          @id @default(uuid()) @db.Uuid
  lessonId     String          @unique @db.Uuid
  lesson       LmsLesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  instructions String?
  dueAt        DateTime?
  maxScore     Int             @default(100)
  submissions  LmsSubmission[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([lessonId])
}

// Entrega de una tarea por un estudiante. Constraint @@unique([assignmentId, studentId])
// garantiza una sola entrega por (tarea, estudiante). `fileUrl` se sube vía Vercel Blob
// (server action `uploadLmsFile`); `textContent` permite entregas en línea.
// El ciclo de estado lo maneja `gradeSubmission()` en server action.
model LmsSubmission {
  id           String              @id @default(uuid()) @db.Uuid
  assignmentId String              @db.Uuid
  assignment   LmsAssignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String              @db.Uuid
  student      User                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fileUrl      String?
  textContent  String?
  status       LmsSubmissionStatus @default(PENDIENTE)
  score        Float?
  feedback     String?
  submittedAt  DateTime?
  gradedAt     DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@index([assignmentId])
  @@index([status])
}

// ─── Fase 2: Libro de Calificaciones (Gradebook) ────────────────────────────
// Unidad evaluable del curso. `weight` es el porcentaje (1.0 = 100%, 0.2 = 20%)
// del promedio final. Se vincula opcionalmente a un LmsAssignment (tarea) o a
// un Exam de Aulika (examen embedido). Cada LmsGrade es la nota individual.
model LmsGradebookItem {
  id           String               @id @default(uuid()) @db.Uuid
  courseId     String               @db.Uuid
  course       LmsCourse            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title        String
  type         LmsGradebookItemType
  weight       Float                @default(1)
  assignmentId String?              @db.Uuid
  examId       String?              @db.Uuid
  exam         Exam?                @relation(fields: [examId], references: [id], onDelete: SetNull)
  grades       LmsGrade[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([courseId])
  @@index([examId])
}

// Nota individual de un estudiante en una unidad del Gradebook. El promedio
// final del curso se calcula con `calculateFinalGrade()` en
// `src/features/lms/lib/gradebook.ts` filtrando por score no nulo.
model LmsGrade {
  id              String           @id @default(uuid()) @db.Uuid
  gradebookItemId String           @db.Uuid
  gradebookItem   LmsGradebookItem @relation(fields: [gradebookItemId], references: [id], onDelete: Cascade)
  studentId       String           @db.Uuid
  student         User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  score           Float
  feedback        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([gradebookItemId, studentId])
  @@index([studentId])
}

// ─── Fase 3: Foros de Comunicación y Comunidad ────────────────────────────────
// Cada curso tiene uno o varios foros (tableros temáticos). Dentro de un foro
// hay hilos (ForumThread, uno por pregunta o anuncio) y posts (ForumPost, las
// respuestas). Los posts admiten anidamiento vía parent_post_id para renders
// recursivos estilo Reddit/GitHub. El body es markdown→HTML sanitizado
// server-side en `src/shared/lib/sanitize.ts` antes de persistir: nunca se
// guarda HTML crudo del usuario.
model LmsForum {
  id          String           @id @default(uuid()) @db.Uuid
  courseId    String           @db.Uuid
  course      LmsCourse        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  // Orden interno del foro en la página del curso.
  order       Int              @default(0)
  // Si está bloqueado, ningún usuario puede crear nuevos hilos ni responder.
  archived    Boolean          @default(false)
  threads     LmsForumThread[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([courseId])
}

// Hilo de conversación dentro de un foro. `pinned` lo sube en la lista,
// `locked` impide nuevas respuestas (suele usarse para anuncios resueltos).
model LmsForumThread {
  id         String         @id @default(uuid()) @db.Uuid
  forumId    String         @db.Uuid
  forum      LmsForum       @relation(fields: [forumId], references: [id], onDelete: Cascade)
  title      String
  authorId   String         @db.Uuid
  author     User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  posts      LmsForumPost[]
  pinned     Boolean        @default(false)
  locked     Boolean        @default(false)
  // Set automáticamente cuando llega la primera respuesta: optimiza orden por actividad.
  lastPostAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([forumId])
  @@index([authorId])
  @@index([pinned, lastPostAt])
}

// Post individual. `parentPostId` permite respuestas anidadas. El body se
// almacena como Markdown crudo (no HTML). El render en UI siempre pasa por
// `sanitizeForumMarkdown()` que lo convierte a HTML seguro antes de inyectarlo.
// `editedAt` se setea cuando el autor modifica el post original (no aplica a
// ediciones de admin).
model LmsForumPost {
  id           String         @id @default(uuid()) @db.Uuid
  threadId     String         @db.Uuid
  thread       LmsForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  parentPostId String?        @db.Uuid
  parentPost   LmsForumPost?  @relation("ForumPostAnswers", fields: [parentPostId], references: [id], onDelete: Cascade)
  answers      LmsForumPost[] @relation("ForumPostAnswers")
  authorId     String         @db.Uuid
  author       User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  // Markdown crudo (≤ 16 KB visible). Se sanitiza al renderizar.
  body         String         @db.Text
  editedAt     DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([threadId])
  @@index([parentPostId])
  @@index([authorId])
  @@index([createdAt])
}

// ─── Fase 3: Notificaciones in-app (LmsNotification) ────────────────────────
// La barra de navegación usa este modelo para mostrar el Bell Icon. Las
// fuentes principales hoy son las respuestas en foros (NEW_POST), pero el
// schema es extensible vía `type`. El render en UI lo maneja Sonnet.
model LmsNotification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // NEW_POST | GRADE_POSTED | ANNOUNCEMENT | ...
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ─── Fase 4: Gamificación (Streak / Badge / PointEvent) ──────────────────────

// Racha diaria por estudiante. Una fila por User. `lastActiveOn` se compara con
// la fecha actual para decidir si incrementar (ayer) o resetear (>ayer). Los
// `freezeTokens` permiten preservar la racha un día sin actividad (regalo del
// profesor o recompensa por hito).
model LmsStreak {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @unique @db.Uuid
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastActiveOn  DateTime? @db.Date
  freezeTokens  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
}

// Catálogo global de insignias. `criteria` es un JSON con reglas declarativas
// (ej. {type: "TOTAL_POINTS", threshold: 100}) que el motor evalúa contra las
// estadísticas del usuario. `pointsReward` se acredita como PointEvent BONUS
// al desbloquear.
model LmsBadge {
  id           String         @id @default(uuid()) @db.Uuid
  code         String         @unique
  name         String
  description  String
  icon         String
  pointsReward Int            @default(0)
  criteria     Json
  active       Boolean        @default(true)
  awardedTo    LmsUserBadge[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([code])
  @@index([active])
}

// Relación M:N estudiante-insignia. `awardedReason` se persiste para auditoría
// (ej. "Reached 7-day streak" o "Primer examen con 7.0"). Constraint única
// garantiza una fila por par (user, badge).
model LmsUserBadge {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId       String   @db.Uuid
  badge         LmsBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt     DateTime @default(now())
  awardedReason String?

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

// Log append-only de cada acreditación de puntos. El total del usuario se
// calcula al vuelo con `SUM(amount) WHERE userId`. `dedupeKey` (opcional y
// UNIQUE) garantiza idempotencia: si dos eventos llegan con la misma clave,
// el segundo falla con P2002 y se ignora silenciosamente. Esto es clave para
// la consistencia bajo reintentos o webhooks duplicados.
model LmsPointEvent {
  id         String         @id @default(uuid()) @db.Uuid
  userId     String         @db.Uuid
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount     Int
  reason     String
  sourceType LmsPointSource
  sourceId   String?        @db.Uuid
  courseId   String?        @db.Uuid
  course     LmsCourse?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  dedupeKey  String?        @unique
  createdAt  DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([courseId])
  @@index([sourceType])
}

// Privacidad del ranking por curso. Una fila por (user, course) cuando el
// estudiante opta por ocultar su nombre del leaderboard público. La UI llama
// `toggleLeaderboardOptOut` que crea/elimina la fila. La query del leaderboard
// hace left-join y marca `isAnonymous = true` para esos usuarios.
model LmsLeaderboardOptOut {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId   String    @db.Uuid
  course     LmsCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  optedOutAt DateTime  @default(now())

  @@unique([userId, courseId])
  @@index([courseId])
}

// ─── Fase 5: Certificados ─────────────────────────────────────────────────────
// Certificado de finalización emitido por el docente/admin cuando un estudiante
// completa un curso. `verificationCode` es el token público para la URL de
// verificación. `revokedAt` permite invalidar un certificado sin borrarlo.

model LmsCertificate {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId         String    @db.Uuid
  course           LmsCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  verificationCode String    @unique @default(cuid())
  finalGrade       Decimal?  @db.Decimal(3, 1)
  // Fase 5: URLs de los assets subidos a Cloudinary.
  pdfUrl           String?
  qrCodeUrl        String?
  issuedAt         DateTime  @default(now())
  revokedAt        DateTime?

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([verificationCode])
}

// ─── Aula Sincrónica (Fase 6) ─────────────────────────────────────────────────

enum LiveSessionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELED
}

enum LiveAttendanceRole {
  TEACHER
  STUDENT
  GUEST
  ASSISTANT
}

enum LiveRecordingStatus {
  NONE
  PENDING
  READY
  FAILED
}

// Sesión sincrónica de clase en vivo. Cada sesión crea una "room" en Daily.co
// y persiste join/leave events para construir el registro de asistencia. La
// grabación se descarga vía webhook `recording.ready-to-download`.
model LmsLiveSession {
  id                   String                  @id @default(uuid()) @db.Uuid
  courseId             String                  @db.Uuid
  course               LmsCourse               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title                String
  description          String?
  scheduledAt          DateTime
  durationMin          Int                     @default(60)
  // Datos de la room en Daily.co. dailyRoomName es único por plataforma y la
  // URL es lo que los clientes usan para unirse. Se borra la room cuando la
  // sesión termina o se cancela.
  dailyRoomName        String                  @unique
  dailyRoomUrl         String
  dailyRoomExpiresAt   DateTime
  maxParticipants      Int?
  status               LiveSessionStatus       @default(SCHEDULED)
  createdById          String                  @db.Uuid
  createdBy            User                    @relation("LmsLiveSessionCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  startedAt            DateTime?
  endedAt              DateTime?
  // Marca temporal del recordatorio 1h antes enviado vía Brevo. Permite
  // re-ejecuciones idempotentes del cron `/api/cron/live-reminders`.
  reminderSentAt       DateTime?
  // Grabación subida post-sesión (auto-fetch vía Daily webhook).
  recordingMuxAssetId  String?
  recordingUrl         String?
  recordingDurationSec Int?
  recordingStatus      LiveRecordingStatus     @default(NONE)
  attendances          LmsLiveAttendance[]
  chatMessages         LmsLiveChatMessage[]
  whiteboardSnapshots  LmsWhiteboardSnapshot[]
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@index([courseId])
  @@index([status])
  @@index([scheduledAt])
  @@index([createdById])
}

// Registro de asistencia por participante. Una fila por join (varias si la
// persona entra/sale varias veces durante la misma sesión).
model LmsLiveAttendance {
  id                 String             @id @default(uuid()) @db.Uuid
  sessionId          String             @db.Uuid
  session            LmsLiveSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId             String             @db.Uuid
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  role               LiveAttendanceRole @default(STUDENT)
  displayName        String
  joinedAt           DateTime
  leftAt             DateTime?
  durationSec        Int?
  // dailyParticipantId: id que Daily devuelve para matching en webhooks.
  dailyParticipantId String?

  @@index([sessionId])
  @@index([userId])
  @@index([sessionId, userId])
}

// Mensaje de chat en vivo durante la sesión. Soft-delete vía deletedAt.
model LmsLiveChatMessage {
  id        String         @id @default(uuid()) @db.Uuid
  sessionId String         @db.Uuid
  session   LmsLiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String         @db.Uuid
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  sentAt    DateTime       @default(now())
  deletedAt DateTime?

  @@index([sessionId, sentAt])
  @@index([userId])
}

// Snapshot de pizarra tldraw (PNG en Cloudinary). El profesor o estudiante
// puede capturar la pizarra en cualquier momento; queda como material
// descargable de la sesión.
model LmsWhiteboardSnapshot {
  id        String         @id @default(uuid()) @db.Uuid
  sessionId String         @db.Uuid
  session   LmsLiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String         @db.Uuid
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  pngUrl    String
  width     Int
  height    Int
  title     String?
  createdAt DateTime       @default(now())

  @@index([sessionId, createdAt])
  @@index([userId])
}

// ─── Categorías LMS (N a N con LmsCourse) ───────────────────────────────────

// Categoría de cursos. Cada institución administra sus categorías (CRUD admin
// en /[slug]/aula/categorias). Una categoría puede venderse como "Pack Completo"
// si `isBundle=true && bundlePrice != null && isPublic=true`: al comprarla el
// estudiante se inscribe en TODOS los cursos asociados a la categoría.
model LmsCategory {
  id                    String             @id @default(uuid()) @db.Uuid
  academicInstitutionId String             @db.Uuid
  academicInstitution   AcademicInstitution @relation(fields: [academicInstitutionId], references: [id], onDelete: Cascade)
  name                  String
  slug                  String
  description           String?
  coverImageUrl         String?
  order                 Int                @default(0)
  // Venta como Pack Completo. Si true + bundlePrice != null + isPublic=true,
  // aparece como item comprable en el catálogo público.
  isBundle              Boolean            @default(false)
  bundlePrice           Float?
  // Visibilidad en el catálogo público (sin venta todavía).
  isPublic              Boolean            @default(false)
  courses               LmsCourseCategory[]
  lmsOrders             LmsOrder[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@unique([academicInstitutionId, slug])
  @@index([academicInstitutionId, order])
  @@index([academicInstitutionId, isBundle])
}

// Tabla intermedia N a N entre LmsCourse y LmsCategory. Un curso puede estar
// en varias categorías; una categoría puede tener varios cursos.
model LmsCourseCategory {
  courseId    String      @db.Uuid
  course      LmsCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  categoryId  String      @db.Uuid
  category    LmsCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())

  @@id([courseId, categoryId])
  @@index([categoryId])
}
