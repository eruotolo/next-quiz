# PostgreSQL (Docker)
POSTGRES_USER=quiz
POSTGRES_PASSWORD=quiz_password
POSTGRES_DB=quiz_db

# Prisma
DATABASE_URL="postgresql://quiz:quiz_password@localhost:5434/quiz_db?schema=public"

# Auth.js v5 (admin)
# Generate: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Student session cookie (jose HS256)
# Generate: openssl rand -base64 32
STUDENT_SESSION_SECRET=
