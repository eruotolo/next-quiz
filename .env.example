# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES TEMPLATE
# Copiar a: .env.local (desarrollo) o .env.production.remote (producción)
# Ambos archivos están en .gitignore — NUNCA commitear valores reales.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
# Dev: Docker local (credenciales hardcodeadas en docker-compose.yml)
# Prod: Vercel Postgres / Neon connection string
DATABASE_URL=

# ─── NextAuth v5 ──────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=
# Dev: http://localhost:3000 — Prod: https://www.aulika.cl
AUTH_URL=

# ─── Student session cookie (jose HS256) ──────────────────────────────────────
# Generate: openssl rand -base64 32
STUDENT_SESSION_SECRET=

# ─── MercadoPago ──────────────────────────────────────────────────────────────
# Dev: credenciales TEST-* (sandbox) — Prod: credenciales APP_USR-* (producción)
# Panel: https://www.mercadopago.cl/developers/panel/credentials
MP_PUBLIC_KEY=
# Prefijo NEXT_PUBLIC_ para exponerla al cliente (necesaria para tokenizar tarjetas)
NEXT_PUBLIC_MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
MP_CLIENT_ID=
MP_CLIENT_SECRET=
# Webhook URL de producción: https://www.aulika.cl/api/webhooks/mercadopago
MP_WEBHOOK_SECRET=
# Base URL para back_url de MP (debe ser HTTPS). Dev: URL de ngrok o https://www.aulika.cl
MP_BACK_URL_BASE=
# IDs de planes recurrentes (crear en panel MP → Suscripciones → Planes)
MP_PLAN_DOCENTE_MONTHLY=
MP_PLAN_DOCENTE_ANNUAL=
MP_PLAN_COLEGIO_MONTHLY=
MP_PLAN_COLEGIO_ANNUAL=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Crear en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Vercel ───────────────────────────────────────────────────────────────────
# Generar en: https://vercel.com/account/tokens
VERCEL_TOKEN=

# ─── Admin seed ───────────────────────────────────────────────────────────────
ADMIN_PASSWORD=
ADMIN_NAME=
ADMIN_LASTNAME=
ADMIN_EMAIL=
ADMIN_RUT=

# ─── Google Analytics (GA4) ───────────────────────────────────────────────────
# Obtener en: https://analytics.google.com → Admin → Data Streams → Measurement ID
# Formato: G-XXXXXXXXXX
# Dejar vacío en .env.local para no trackear en desarrollo
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-BF3SJQWPED
# Desabilita Google Analytics completamente (útil para demo, GDPR, etc.)
# Valores válidos: 'true' (desabilita), vacío o no seteado (habilita)
NEXT_PUBLIC_GA_DISABLED=
