{
    "name": "aulika",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev --turbopack",
        "clean": "rm -rf .next",
        "devBuild": "rm -rf .next && next build",
        "build": "prisma generate && DATABASE_URL=$DIRECT_DATABASE_URL prisma migrate deploy && tsx prisma/seeders/gamification-badges-cli.ts && tsx prisma/seeders/plan-codes-cli.ts && tsx prisma/seeders/demo.ts && next build",
        "start": "next start",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "prettier --write .",
        "type-check": "tsc --noEmit",
        "db:generate": "dotenv -e .env.local -- prisma generate",
        "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
        "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
        "db:seed:badges": "dotenv -e .env.local -- tsx prisma/seeders/gamification-badges-cli.ts",
        "db:seed:plans": "dotenv -e .env.local -- tsx prisma/seeders/plan-codes-cli.ts",
        "db:seed:local": "dotenv -e .env.local -- tsx prisma/seeders/testing/index.ts local",
        "db:seed:bulk": "dotenv -e .env.local -- tsx prisma/seeders/testing/index.ts bulk",
        "db:seed:e2e": "dotenv -e .env.local -- tsx prisma/seeders/testing/index.ts e2e",
        "db:seed:aula": "dotenv -e .env.local -- tsx prisma/seeders/testing/index.ts aula",
        "db:seed:demo": "dotenv -e .env.local -- tsx prisma/seeders/demo.ts",
        "db:seed:mp": "dotenv -e .env.local -- tsx prisma/seeders/mp-plans.ts",
        "db:backfill": "dotenv -e .env.local -- tsx prisma/scripts/backfill-institution.ts",
        "db:studio": "dotenv -e .env.local -- prisma studio",
        "test": "vitest",
        "test:run": "vitest run",
        "test:watch": "vitest --watch",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "dotenv -e .env.local -- playwright test",
        "test:e2e:ui": "dotenv -e .env.local -- playwright test --ui"
    },
    "dependencies": {
        "@ai-sdk/google": "^3.0.83",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@getbrevo/brevo": "^5.0.4",
        "@hookform/resolvers": "^3.10.0",
        "@mux/mux-node": "^14.1.1",
        "@mux/mux-player-react": "^3.13.0",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.0.0",
        "@react-pdf/renderer": "^4.5.1",
        "@tldraw/editor": "2.4.0",
        "@tldraw/store": "2.4.0",
        "@tldraw/tldraw": "2.4.0",
        "@types/qrcode": "^1.5.6",
        "@vercel/blob": "^2.5.0",
        "ai": "^6.0.209",
        "bcryptjs": "^2.4.3",
        "class-variance-authority": "^0.7.1",
        "cloudinary": "^2.10.0",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "driver.js": "^1.6.0",
        "framer-motion": "^11.15.0",
        "jose": "^5.9.6",
        "lucide-react": "^1.14.0",
        "mercadopago": "^2.12.1",
        "next": "^16.0.0",
        "next-auth": "5.0.0-beta.25",
        "next-themes": "^0.4.4",
        "pg": "^8.22.0",
        "qrcode": "^1.5.4",
        "radix-ui": "^1.4.3",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-hook-form": "^7.54.2",
        "react-imask": "^7.6.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tailwindcss-animate": "^1.0.7",
        "xlsx": "^0.18.5",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "@playwright/test": "^1.60.0",
        "@tailwindcss/postcss": "^4.0.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "^22.10.5",
        "@types/pg": "^8.20.0",
        "@types/react": "^19.0.7",
        "@types/react-dom": "^19.0.3",
        "@vitejs/plugin-react": "^4.7.0",
        "@vitest/coverage-v8": "^4.1.6",
        "dotenv-cli": "^11.0.0",
        "jsdom": "^29.1.1",
        "postcss": "^8.5.1",
        "prettier": "^3.4.2",
        "prettier-plugin-tailwindcss": "^0.6.10",
        "prisma": "^7.0.0",
        "tailwindcss": "^4.0.0",
        "tsx": "^4.19.2",
        "typescript": "^5.7.3",
        "vercel": "^54.1.0",
        "vitest": "^4.1.6"
    },
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=20"
    }
}
